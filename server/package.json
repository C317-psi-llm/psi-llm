{
  "name": "mentis-backend",
  "version": "1.0.0",
  "description": "Mentis Tech - Backend MVP",
  "license": "MIT",
  "author": "Mentis Tech",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "knex --knexfile ./knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile ./knexfile.js migrate:rollback",
    "seed": "knex --knexfile ./knexfile.js seed:run",
    "migrate-and-seed": "npm run migrate && npm run seed",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^6.15.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^2.5.1",
    "morgan": "^1.10.0",
    "pg": "^8.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/knex": "^0.16.1",
    "@types/morgan": "^1.9.4",
    "@types/cors": "^2.8.12",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^9.0.1"
  }
}
