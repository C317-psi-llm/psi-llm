{
  "name": "mentis-server",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "seed": "ts-node src/db/seed.ts",
    "docker:build": "docker compose -f ../docker-compose.yml build --no-cache backend",
    "docker:up": "docker compose -f ../docker-compose.yml up --build backend",
    "docker:up:dev": "docker compose -f ../docker-compose.yml up --build",
    "docker:down": "docker compose -f ../docker-compose.yml down -v",
    "migrate:docker": "docker compose -f ../docker-compose.yml exec backend npm run migrate",
    "seed:docker": "docker compose -f ../docker-compose.yml exec backend npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^6.14.3",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
